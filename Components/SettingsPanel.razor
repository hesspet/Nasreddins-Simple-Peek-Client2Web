<section class="panel settings-panel">
    <label class="toggle-control">
        <span>@GermanText.HelpSystemHidden</span>
        <input type="checkbox" checked="@State.IsHelpSystemHidden" @onchange="ChangeHelpSystemHidden" />
        <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@AppConstants.HideHelpSystemHelpIdentifier" Title="@GermanText.HelpSystemHidden" OnOpenHelp="OnOpenHelp" />
    </label>
    <label class="toggle-control">
        <span>@GermanText.DarkMode</span>
        <input type="checkbox" checked="@State.IsDarkModeEnabled" @onchange="ChangeDarkMode" />
    </label>
    <label class="toggle-control">
        <span>@GermanText.CloseButtonViewAfterSend</span>
        <input type="checkbox" checked="@State.ShouldCloseButtonViewAfterSend" @onchange="ChangeShouldCloseButtonViewAfterSend" />
    </label>

    <div class="settings-group">
        <div class="settings-heading-with-help">
            <h3>@GermanText.Bluetooth</h3>
            <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@AppConstants.ForgetRememberedDeviceHelpIdentifier" Title="@GermanText.ForgetRememberedDevice" OnOpenHelp="OnOpenHelp" />
        </div>
        <div class="status-line">
            <span>@GermanText.RememberedDevice</span>
            <strong>@RememberedDeviceText</strong>
        </div>
        @if (State.RememberedBluetoothDevice is not null)
        {
            <button class="button" disabled="@State.IsBluetoothOperationRunning" @onclick="OnForgetRememberedDevice">
                @GermanText.ForgetRememberedDevice
            </button>
        }
    </div>

    <div class="settings-group">
        <h3>@GermanText.Display</h3>
        <label class="toggle-control">
            <span>@GermanText.DisplayInverted</span>
            <input type="checkbox" checked="@State.IsDisplayInverted" @onchange="ChangeDisplayInverted" />
            <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@AppConstants.DisplayInvertedHelpIdentifier" Title="@GermanText.DisplayInverted" OnOpenHelp="OnOpenHelp" />
        </label>
        <label class="toggle-control">
            <span>@GermanText.DisplayRotated</span>
            <input type="checkbox" checked="@State.IsDisplayRotated" @onchange="ChangeDisplayRotated" />
        </label>
        <label class="toggle-control">
            <span>@GermanText.SkipSleepDisplayAfterClearDisplay</span>
            <input type="checkbox" checked="@State.ShouldSkipSleepDisplayAfterClearDisplay" @onchange="ChangeShouldSkipSleepDisplayAfterClearDisplay" />
        </label>
    </div>

    <div class="settings-group">
        <div class="settings-heading-with-help">
            <h3>@GermanText.CyclicSleep</h3>
            <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@AppConstants.CyclicSleepHelpIdentifier" Title="@GermanText.CyclicSleep" OnOpenHelp="OnOpenHelp" />
        </div>
        <div class="cycle-setting-row">
            <span>@GermanText.SleepDuration</span>
            <div class="stepper-row">
                <button class="button" @onclick="@(() => OnSetCycleSleepSeconds.InvokeAsync(-5))">-5</button>
                <strong>@State.CycleSleepSeconds s</strong>
                <button class="button" @onclick="@(() => OnSetCycleSleepSeconds.InvokeAsync(5))">+5</button>
            </div>
        </div>
        <div class="cycle-setting-row">
            <span>@GermanText.ListenDuration</span>
            <div class="stepper-row">
                <button class="button" @onclick="@(() => OnSetCycleListenSeconds.InvokeAsync(-5))">-5</button>
                <strong>@State.CycleListenSeconds s</strong>
                <button class="button" @onclick="@(() => OnSetCycleListenSeconds.InvokeAsync(5))">+5</button>
            </div>
        </div>
        <button class="button primary-button" @onclick="OnSendCycleSleepCommand">@GermanText.SendSleepCommand</button>
    </div>

    <div class="settings-group">
        <h3>@GermanText.CameraView</h3>
        <div class="segmented-options">
            @foreach (var cameraViewStyle in Enum.GetValues<CameraViewStyle>())
            {
                <button class="mode-tab @(State.SelectedCameraViewStyle == cameraViewStyle ? "is-active" : "")"
                        @onclick="@(() => OnSetCameraViewStyle.InvokeAsync(cameraViewStyle))">
                    @GermanText.GetCameraViewStyleLabel(cameraViewStyle)
                </button>
            }
        </div>
    </div>

    <div class="settings-group">
        <div class="settings-heading-with-help">
            <h3>@GermanText.CameraControls</h3>
            <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@AppConstants.CameraControlsHelpIdentifier" Title="@GermanText.CameraControls" OnOpenHelp="OnOpenHelp" />
        </div>
        <div class="segmented-options">
            @foreach (var cameraButtonAppearance in AppConstants.CameraButtonAppearances)
            {
                <button class="mode-tab @(State.SelectedCameraButtonAppearance == cameraButtonAppearance ? "is-active" : "")"
                        @onclick="@(() => OnSetCameraButtonAppearance.InvokeAsync(cameraButtonAppearance))">
                    @GermanText.GetCameraButtonAppearanceLabel(cameraButtonAppearance)
                </button>
            }
        </div>
        @if (State.SelectedCameraButtonAppearance == CameraButtonAppearance.Custom)
        {
            <label class="range-control">
                <span>@GermanText.Opacity: @CameraButtonOpacityText</span>
                <input type="range"
                       min="@MinimumCameraButtonOpacityValue"
                       max="@MaximumCameraButtonOpacityValue"
                       step="0.01"
                       value="@CustomCameraButtonOpacityValue"
                       @onchange="ChangeCameraButtonOpacity" />
            </label>
        }
    </div>
</section>

@code {
    [Parameter, EditorRequired] public ApplicationState State { get; set; } = new();
    [Parameter] public bool IsHelpVisible { get; set; }
    [Parameter, EditorRequired] public EventCallback OnSendCycleSleepCommand { get; set; }
    [Parameter, EditorRequired] public EventCallback<CameraButtonAppearance> OnSetCameraButtonAppearance { get; set; }
    [Parameter, EditorRequired] public EventCallback<double> OnSetCameraButtonOpacity { get; set; }
    [Parameter, EditorRequired] public EventCallback<CameraViewStyle> OnSetCameraViewStyle { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnSetCycleListenSeconds { get; set; }
    [Parameter, EditorRequired] public EventCallback<int> OnSetCycleSleepSeconds { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetDarkMode { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetDisplayInverted { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetDisplayRotated { get; set; }
    [Parameter, EditorRequired] public EventCallback OnForgetRememberedDevice { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetHelpSystemHidden { get; set; }
    [Parameter, EditorRequired] public EventCallback<string> OnOpenHelp { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetShouldCloseButtonViewAfterSend { get; set; }
    [Parameter, EditorRequired] public EventCallback<bool> OnSetShouldSkipSleepDisplayAfterClearDisplay { get; set; }

    private string CameraButtonOpacityText =>
        $"{Math.Round(ApplicationStateStore.GetCameraButtonOpacity(State.SelectedCameraButtonAppearance, State.CustomCameraButtonOpacity) * 100)} %";
    private static string MinimumCameraButtonOpacityValue => AppConstants.MinimumCameraButtonOpacity.ToString(CultureInfo.InvariantCulture);
    private static string MaximumCameraButtonOpacityValue => AppConstants.MaximumCameraButtonOpacity.ToString(CultureInfo.InvariantCulture);
    private string CustomCameraButtonOpacityValue => State.CustomCameraButtonOpacity.ToString(CultureInfo.InvariantCulture);
    private string RememberedDeviceText => State.RememberedBluetoothDevice?.Name ?? GermanText.NoRememberedDevice;

    private async Task ChangeDarkMode(ChangeEventArgs changeEventArgs) => await OnSetDarkMode.InvokeAsync(GetBoolean(changeEventArgs));
    private async Task ChangeDisplayInverted(ChangeEventArgs changeEventArgs) => await OnSetDisplayInverted.InvokeAsync(GetBoolean(changeEventArgs));
    private async Task ChangeDisplayRotated(ChangeEventArgs changeEventArgs) => await OnSetDisplayRotated.InvokeAsync(GetBoolean(changeEventArgs));
    private async Task ChangeHelpSystemHidden(ChangeEventArgs changeEventArgs) => await OnSetHelpSystemHidden.InvokeAsync(GetBoolean(changeEventArgs));
    private async Task ChangeShouldCloseButtonViewAfterSend(ChangeEventArgs changeEventArgs) => await OnSetShouldCloseButtonViewAfterSend.InvokeAsync(GetBoolean(changeEventArgs));
    private async Task ChangeShouldSkipSleepDisplayAfterClearDisplay(ChangeEventArgs changeEventArgs) => await OnSetShouldSkipSleepDisplayAfterClearDisplay.InvokeAsync(GetBoolean(changeEventArgs));

    private async Task ChangeCameraButtonOpacity(ChangeEventArgs changeEventArgs)
    {
        if (double.TryParse(Convert.ToString(changeEventArgs.Value, CultureInfo.InvariantCulture), NumberStyles.Float, CultureInfo.InvariantCulture, out var nextValue))
        {
            await OnSetCameraButtonOpacity.InvokeAsync(nextValue);
        }
    }

    private static bool GetBoolean(ChangeEventArgs changeEventArgs) => changeEventArgs.Value is bool value && value;
}
