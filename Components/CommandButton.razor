<button class="camera-command-button" disabled="@Disabled" @onclick="@(() => OnSendCommand.InvokeAsync(CommandText))">
    @if (!string.IsNullOrWhiteSpace(Icon))
    {
        <span class="command-icon">@((MarkupString)Icon)</span>
    }
    <span>@Label</span>
</button>

@code {
    [Parameter, EditorRequired] public string CommandText { get; set; } = "";
    [Parameter] public bool Disabled { get; set; }
    [Parameter] public string Icon { get; set; } = "";
    [Parameter, EditorRequired] public string Label { get; set; } = "";
    [Parameter, EditorRequired] public EventCallback<string> OnSendCommand { get; set; }
}
