@page "/"
@implements IDisposable
@using System.Globalization
@using System.Text.Json
@inject ApplicationStateStore StateStore
@inject SettingsStorage SettingsStorage
@inject IJSRuntime JavaScriptRuntime
@inject AudioSpyMatcher AudioSpyMatcher
@inject BluetoothPrompterClient BluetoothPrompterClient
@inject CommandService CommandService
@inject FullscreenService FullscreenService
@inject BackExitGuardService BackExitGuardService

<PageTitle>@GermanText.ApplicationTitle</PageTitle>

@if (State.FullScreenMode is not null)
{
    <VideoFullScreen
        State="State"
        IsHelpVisible="IsHelpVisible"
        OnBack="CloseFullScreenMode"
        OnClearDisplay="CommandService.ClearDisplayAsync"
        OnHideControls="@(() => UpdateState(currentState => currentState with { AreFullScreenControlsVisible = false }))"
        OnShowControls="@(() => UpdateState(currentState => currentState with { AreFullScreenControlsVisible = true }))"
        OnSelectCardSuit="SelectCardSuit"
        OnSendCardRank="CommandService.SendCardRankAsync"
        OnSendCommand="CommandService.SendCommandAndMaybeCloseOverlayAsync"
        OnSendSymbol="CommandService.SendSymbolAsync"
        OnSetFakeVideoPaused="SetFakeVideoPaused"
        OnSetSymbolText="SetSymbolText"
        OnSetZoom="SetCameraZoom"
        OnOpenHelp="OpenHelp" />
}
else
{
    <div class="@PageClass">
        <div class="drawer-backdrop @(State.IsMenuOpen ? "is-visible" : "")">
            <aside class="drawer-panel">
                <header class="drawer-header">
                    <img src="icon-192.png" alt="" class="title-icon" />
                    <div>
                        <div class="drawer-title">@GermanText.Menu</div>
                        <div class="metadata-line">@MetadataLine</div>
                    </div>
                </header>
                <nav class="drawer-items" aria-label="@GermanText.Menu">
                    @foreach (var menuItem in AppConstants.MenuItems)
                    {
                        <button class="drawer-item @(State.SelectedMenuItem == menuItem ? "is-active" : "")"
                                @onclick="@(() => SelectMenuItem(menuItem))">
                            <span class="drawer-indicator"></span>
                            <span>@GermanText.GetMenuLabel(menuItem)</span>
                        </button>
                    }
                    @if (IsHelpVisible)
                    {
                        <button class="drawer-item" @onclick="@(() => OpenHelp(AppConstants.HelpOverviewIdentifier))">
                            <span class="drawer-indicator"></span>
                            <span>@GermanText.Help</span>
                        </button>
                    }
                </nav>
            </aside>
            <button class="drawer-dismiss" aria-label="@GermanText.CloseMenu" @onclick="CloseMenu"></button>
        </div>

        <main class="app-shell">
            <header class="app-header">
                <div class="header-top-row">
                    <button class="icon-button menu-toggle" aria-label="@GermanText.OpenMenu" @onclick="OpenMenu">☰</button>
                    <div class="title-block">
                        <div class="title-row">
                            <img src="icon-192.png" alt="" class="title-icon" />
                            <h1>@GermanText.ApplicationTitle</h1>
                        </div>
                        <p class="metadata-line">@MetadataLine</p>
                    </div>
                    <button class="icon-button"
                            type="button"
                            aria-label="@GermanText.FullscreenTitle"
                            title="@GermanText.FullscreenTitle"
                            @onclick="TryFullscreen">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                            <polyline points="15 3 21 3 21 9" />
                            <polyline points="9 21 3 21 3 15" />
                            <line x1="21" y1="3" x2="14" y2="10" />
                            <line x1="3" y1="21" x2="10" y2="14" />
                        </svg>
                    </button>
                    <HelpButton IsVisible="IsHelpVisible" HelpIdentifier="@CurrentViewHelpIdentifier" Title="@CurrentViewHelpTitle" OnOpenHelp="OpenHelp" />
                </div>
                <div class="header-status-row">
                    <span class="connection-state @(State.IsConnected || State.IsTestModeEnabled ? "is-connected" : "")">
                        <span class="state-dot"></span>
                        @GermanText.GetConnectionStatusText(State.ConnectionStatus)
                    </span>
                </div>
            </header>

            <h2 class="screen-heading">@CurrentViewTitle</h2>

            @if (State.SelectedMenuItem == MenuItem.Client)
            {
                @if (State.SelectedClientSubMode == ClientSubMode.AudioSpy)
                {
                    <AudioSpyPanel State="State" OnSendCommand="CommandService.SendCommandAsync" OnBack="CloseAudioSpy" />
                }
                else
                {
                    <ClientPanel @ref="clientPanel"
                        State="State"
                        IsHelpVisible="IsHelpVisible"
                        OnCancelBluetoothOperation="CancelBluetoothOperation"
                        OnClearDisplay="CommandService.ClearDisplayAsync"
                        OnConnect="Connect"
                        OnDisconnect="Disconnect"
                        OnOpenAudioSpy="OpenAudioSpy"
                        OnOpenFullScreenMode="OpenFullScreenMode"
                        OnOpenHelp="OpenHelp"
                        OnReconnect="ReconnectRememberedDevice"
                        OnSetTestMode="SetTestMode" />
                }
            }
            else if (State.SelectedMenuItem == MenuItem.Einstellungen)
            {
                <SettingsPanel @ref="settingsPanel"
                    State="State"
                    IsHelpVisible="IsHelpVisible"
                    CurrentProfileName="@CurrentProfileDisplayName"
                    ProfileErrorText="@profileErrorText"
                    OnExportProfile="ExportProfile"
                    OnImportProfileSelected="ImportProfile"
                    OnSendSleepResetCommand="SendSleepResetCommand"
                    OnSetCameraButtonAppearance="SetCameraButtonAppearance"
                    OnSetCameraButtonOpacity="SetCameraButtonOpacity"
                    OnSetCameraViewStyle="SetCameraViewStyle"
                    OnSetTestVideoFileSelection="SetTestVideoFileSelection"
                    OnSetVideoSourceType="SetVideoSourceType"
                    OnSetCycleListenSeconds="SetCycleListenSeconds"
                    OnSetCycleSleepSeconds="SetCycleSleepSeconds"
                    OnSetDarkMode="SetDarkMode"
                    OnSetDisplayInverted="SetDisplayInverted"
                    OnSetDisplayRotated="SetDisplayRotated"
                    OnForgetRememberedDevice="ForgetRememberedDevice"
                    OnSetHelpSystemHidden="SetHelpSystemHidden"
                    OnOpenHelp="OpenHelp"
                    OnSetAudioSpyMappings="SetAudioSpyMappings"
                    OnSetShouldCloseButtonViewAfterSend="SetShouldCloseButtonViewAfterSend"
                    OnSetShouldSkipSleepDisplayAfterClearDisplay="SetShouldSkipSleepDisplayAfterClearDisplay" />
            }
            else if (State.SelectedMenuItem == MenuItem.Log)
            {
                <LogPanel MessageLog="State.MessageLog" />
            }
            else
            {
                <AboutPanel />
            }
        </main>
    </div>
}

<HelpSheet
    IsOpen="isHelpSheetOpen"
    IsDarkTheme="State.IsDarkModeEnabled"
    HelpIdentifier="@activeHelpIdentifier"
    OnClose="CloseHelp"
    OnSelectHelp="OpenHelp" />

@code {
    private bool haveSettingsLoaded;
    private bool isHelpSheetOpen;
    private string activeHelpIdentifier = AppConstants.HelpOverviewIdentifier;
    private string currentProfileName = "";
    private string profileErrorText = "";
    private Timer? recordingTimer;
    private ClientPanel? clientPanel;
    private SettingsPanel? settingsPanel;
    private IDisposable? backHandlerRegistration;
    private ApplicationState State => StateStore.State;
    private bool IsHelpVisible => !State.IsHelpSystemHidden;
    private string PageClass => State.IsDarkModeEnabled ? "app-root dark-theme" : "app-root";
    private string MetadataLine => GermanText.GetMetadataLine(BuildTimestampText);
    private string CurrentProfileDisplayName => string.IsNullOrWhiteSpace(currentProfileName) ? GermanText.StandardProfile : currentProfileName;
    private static string BuildTimestampText { get; } = GetBuildTimestampText();
    private string CurrentViewHelpIdentifier => State.SelectedMenuItem switch
    {
        MenuItem.Client when State.SelectedClientSubMode == ClientSubMode.AudioSpy => AppConstants.AudioSpyHelpIdentifier,
        MenuItem.Einstellungen => AppConstants.SettingsHelpIdentifier,
        MenuItem.Log => AppConstants.LogHelpIdentifier,
        MenuItem.About => AppConstants.AboutHelpIdentifier,
        _ => AppConstants.ClientHelpIdentifier
    };
    private string CurrentViewTitle => State.SelectedMenuItem == MenuItem.Client && State.SelectedClientSubMode == ClientSubMode.AudioSpy
        ? GermanText.AudioSpy
        : GermanText.GetMenuLabel(State.SelectedMenuItem);
    private string CurrentViewHelpTitle => CurrentViewTitle;

    protected override async Task OnInitializedAsync()
    {
        backHandlerRegistration = BackExitGuardService.RegisterBackHandler(CanHandleBack, HandleBackAsync);
        StateStore.StateChanged += HandleStateChanged;
        var persistedSettings = await SettingsStorage.LoadSettingsAsync();
        currentProfileName = await SettingsStorage.LoadCurrentProfileNameAsync();

        if (persistedSettings is not null)
        {
            StateStore.ApplyPersistedSettings(persistedSettings);
        }

        haveSettingsLoaded = true;
    }

    private static string GetBuildTimestampText()
    {
        if (DateTimeOffset.TryParse(GeneratedBuildInformation.BuildTimestampUtc, CultureInfo.InvariantCulture, DateTimeStyles.AssumeUniversal, out var parsedBuildTimestamp))
        {
            return ApplicationStateStore.FormatEuropeanDateTime(parsedBuildTimestamp);
        }

        return ApplicationStateStore.FormatEuropeanDateTime(DateTimeOffset.Now);
    }

    private void HandleStateChanged()
    {
        _ = InvokeAsync(StateHasChanged);
    }

    private async Task SaveSettingsAsync()
    {
        if (!haveSettingsLoaded)
        {
            return;
        }

        await SettingsStorage.SaveSettingsAsync(StateStore.GetPersistedSettings());
    }

    private void UpdateState(Func<ApplicationState, ApplicationState> updateState)
    {
        StateStore.Update(updateState);
    }

    private async Task UpdateStateAndSaveAsync(Func<ApplicationState, ApplicationState> updateState)
    {
        StateStore.Update(updateState);
        await SaveSettingsAsync();
    }

    private void OpenMenu() => UpdateState(currentState => currentState with { IsMenuOpen = true });

    private void CloseMenu() => UpdateState(currentState => currentState with { IsMenuOpen = false });

    private async Task TryFullscreen()
    {
        var wurdeAktiviert = await FullscreenService.TryFullscreenAsync();

        if (!wurdeAktiviert)
        {
            UpdateState(currentState => currentState with { LastResponse = GermanText.FullscreenUnsupported });
        }
    }

    private bool CanHandleBack()
    {
        if (isHelpSheetOpen || State.IsMenuOpen)
        {
            return true;
        }

        if (State.FullScreenMode is null)
        {
            if (State.SelectedMenuItem == MenuItem.Client && clientPanel?.CanHandleBack == true)
            {
                return true;
            }

            if (State.SelectedMenuItem == MenuItem.Einstellungen && settingsPanel?.CanHandleBack == true)
            {
                return true;
            }
        }

        return State.FullScreenMode is not null ||
            (State.SelectedMenuItem == MenuItem.Client && State.SelectedClientSubMode == ClientSubMode.AudioSpy) ||
            State.SelectedMenuItem is MenuItem.Einstellungen or MenuItem.Log or MenuItem.About;
    }

    private async Task HandleBackAsync()
    {
        if (isHelpSheetOpen)
        {
            CloseHelp();
            StateHasChanged();
            return;
        }

        if (State.IsMenuOpen)
        {
            CloseMenu();
            return;
        }

        if (State.FullScreenMode is null)
        {
            if (State.SelectedMenuItem == MenuItem.Client && clientPanel?.CanHandleBack == true && await clientPanel.TryHandleBackAsync())
            {
                return;
            }

            if (State.SelectedMenuItem == MenuItem.Einstellungen && settingsPanel?.CanHandleBack == true && await settingsPanel.TryHandleBackAsync())
            {
                return;
            }
        }

        if (State.FullScreenMode is not null)
        {
            CloseFullScreenMode();
            return;
        }

        if (State.SelectedMenuItem == MenuItem.Client && State.SelectedClientSubMode == ClientSubMode.AudioSpy)
        {
            CloseAudioSpy();
            return;
        }

        if (State.SelectedMenuItem is MenuItem.Einstellungen or MenuItem.Log or MenuItem.About)
        {
            ReturnToPeeker();
        }
    }

    private void OpenHelp(string helpIdentifier)
    {
        if (!IsHelpVisible)
        {
            return;
        }

        activeHelpIdentifier = helpIdentifier;
        isHelpSheetOpen = true;
        UpdateState(currentState => currentState with { IsMenuOpen = false });
    }

    private void CloseHelp()
    {
        isHelpSheetOpen = false;
    }

    private void SelectMenuItem(MenuItem menuItem)
    {
        UpdateState(currentState => currentState with
        {
            SelectedMenuItem = menuItem,
            SelectedClientSubMode = menuItem == MenuItem.Client ? ClientSubMode.Peeker : currentState.SelectedClientSubMode,
            IsMenuOpen = false
        });
    }

    private async Task Connect()
    {
        var wasConnected = await BluetoothPrompterClient.RequestAndConnectAsync(BluetoothScanMode.Filtered);

        if (wasConnected)
        {
            await SynchronizeDisplaySettingsAsync();
            await SaveSettingsAsync();
        }
    }

    private async Task ReconnectRememberedDevice()
    {
        if (State.RememberedBluetoothDevice is null)
        {
            await Connect();
            return;
        }

        var wasConnected = await BluetoothPrompterClient.ReconnectRememberedDeviceAsync(State.RememberedBluetoothDevice);

        if (wasConnected)
        {
            await SynchronizeDisplaySettingsAsync();
            await SaveSettingsAsync();
        }
    }

    private async Task Disconnect()
    {
        await BluetoothPrompterClient.DisconnectAsync();
    }

    private async Task CancelBluetoothOperation()
    {
        await BluetoothPrompterClient.CancelCurrentOperationAsync();
        UpdateState(currentState => currentState with
        {
            ConnectionStatus = ConnectionStatus.NotConnected,
            IsBluetoothOperationRunning = false,
            DiscoveredDevices = Array.Empty<BluetoothDeviceInformation>(),
            SleepingDeviceSearchText = "",
            LastResponse = currentState.ConnectionStatus == ConnectionStatus.Connecting
                ? GermanText.CancelConnection
                : GermanText.CancelSearch
        });
    }

    private async Task SetTestMode(bool nextValue)
    {
        if (nextValue)
        {
            await BluetoothPrompterClient.DisconnectAsync();
            UpdateState(currentState => currentState with
            {
                IsTestModeEnabled = true,
                IsConnected = false,
                ConnectedDeviceName = "",
                ConnectionStatus = ConnectionStatus.TestMode,
                LastResponse = GermanText.TestModeEnabled
            });
            StateStore.AddLogEntry("Testmodus aktiviert.");
            return;
        }

        UpdateState(currentState => currentState with
        {
            IsTestModeEnabled = false,
            ConnectionStatus = ConnectionStatus.NotConnected,
            LastResponse = GermanText.TestModeDisabled
        });
        StateStore.AddLogEntry(GermanText.TestModeDisabled);
    }

    private async Task ForgetRememberedDevice()
    {
        StateStore.ForgetRememberedDevice();
        await SaveSettingsAsync();
    }

    private async Task<bool> SendSleepResetCommand(string deviceName)
    {
        return await CommandService.SendSleepResetCommandAsync();
    }

    private async Task SetDarkMode(bool nextValue) =>
        await UpdateStateAndSaveAsync(currentState => currentState with { IsDarkModeEnabled = nextValue });

    private async Task SetHelpSystemHidden(bool nextValue)
    {
        if (nextValue)
        {
            isHelpSheetOpen = false;
        }

        await UpdateStateAndSaveAsync(currentState => currentState with { IsHelpSystemHidden = nextValue });
    }

    private async Task SetShouldCloseButtonViewAfterSend(bool nextValue) =>
        await UpdateStateAndSaveAsync(currentState => currentState with { ShouldCloseButtonViewAfterSend = nextValue });

    private async Task SetShouldSkipSleepDisplayAfterClearDisplay(bool nextValue) =>
        await UpdateStateAndSaveAsync(currentState => currentState with { ShouldSkipSleepDisplayAfterClearDisplay = nextValue });

    private async Task SetAudioSpyMappings(IReadOnlyList<AudioSpyMapping> mappings) =>
        await UpdateStateAndSaveAsync(currentState => currentState with
        {
            AudioSpyMappings = ApplicationStateStore.NormalizeAudioSpyMappings(mappings)
        });

    private async Task ExportProfile()
    {
        profileErrorText = "";
        var requestedProfileName = await JavaScriptRuntime.InvokeAsync<string?>("prompt", GermanText.ProfileSavePrompt, CurrentProfileDisplayName);

        if (requestedProfileName is null)
        {
            return;
        }

        if (string.IsNullOrWhiteSpace(requestedProfileName))
        {
            profileErrorText = GermanText.ProfileNameMissing;
            return;
        }

        var profileFileName = SettingsStorage.NormalizeProfileFileName(requestedProfileName);
        var profileName = SettingsStorage.GetProfileNameFromFileName(profileFileName);

        if (string.IsNullOrWhiteSpace(profileName))
        {
            profileErrorText = GermanText.ProfileNameMissing;
            return;
        }

        var profileText = SettingsStorage.SerializeProfile(StateStore.GetPersistedSettings());
        await JavaScriptRuntime.InvokeVoidAsync("nasreddinSettingsProfile.downloadProfileFile", profileFileName, profileText);
        currentProfileName = profileName;
        await SettingsStorage.SaveCurrentProfileNameAsync(profileName);
        UpdateState(currentState => currentState with { LastResponse = GermanText.GetProfileSaved(profileName) });
    }

    private async Task ImportProfile(InputFileChangeEventArgs inputFileChangeEventArgs)
    {
        profileErrorText = "";
        var profileFile = inputFileChangeEventArgs.File;

        if (!SettingsStorage.IsAllowedProfileFileName(profileFile.Name))
        {
            profileErrorText = GermanText.ProfileImportInvalidExtension;
            return;
        }

        if (profileFile.Size > AppConstants.MaximumProfileFileBytes)
        {
            profileErrorText = GermanText.ProfileImportFileTooLarge;
            return;
        }

        var profileName = SettingsStorage.GetProfileNameFromFileName(profileFile.Name);

        if (string.IsNullOrWhiteSpace(profileName))
        {
            profileErrorText = GermanText.ProfileNameMissing;
            return;
        }

        PersistedApplicationSettings? importedSettings;

        try
        {
            await using var profileStream = profileFile.OpenReadStream(AppConstants.MaximumProfileFileBytes);
            using var profileReader = new StreamReader(profileStream);
            var profileText = await profileReader.ReadToEndAsync();
            importedSettings = SettingsStorage.DeserializeProfile(profileText);
        }
        catch (JsonException)
        {
            profileErrorText = GermanText.ProfileImportInvalidJson;
            return;
        }
        catch
        {
            profileErrorText = GermanText.ProfileImportReadFailed;
            return;
        }

        if (!TryValidateProfileSettings(importedSettings, out profileErrorText))
        {
            return;
        }

        StateStore.ApplyPersistedSettings(importedSettings!);
        await SaveSettingsAsync();
        currentProfileName = profileName;
        await SettingsStorage.SaveCurrentProfileNameAsync(profileName);
        UpdateState(currentState => currentState with { LastResponse = GermanText.GetProfileImported(profileName) });
    }

    private bool TryValidateProfileSettings(PersistedApplicationSettings? settings, out string errorText)
    {
        errorText = "";

        if (settings is null)
        {
            errorText = GermanText.ProfileImportInvalidJson;
            return false;
        }

        if (!Enum.IsDefined(settings.SelectedCameraViewStyle))
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.SelectedCameraViewStyle));
            return false;
        }

        if (!AppConstants.CameraButtonAppearances.Contains(settings.SelectedCameraButtonAppearance))
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.SelectedCameraButtonAppearance));
            return false;
        }

        if (!AppConstants.VideoSourceTypes.Contains(settings.SelectedVideoSourceType))
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.SelectedVideoSourceType));
            return false;
        }

        if (!double.IsFinite(settings.CustomCameraButtonOpacity) ||
            settings.CustomCameraButtonOpacity < AppConstants.MinimumCameraButtonOpacity ||
            settings.CustomCameraButtonOpacity > AppConstants.MaximumCameraButtonOpacity)
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.CustomCameraButtonOpacity));
            return false;
        }

        if (settings.CycleSleepSeconds < AppConstants.MinimumCycleSleepSeconds || settings.CycleSleepSeconds > AppConstants.MaximumCycleSleepSeconds)
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.CycleSleepSeconds));
            return false;
        }

        if (settings.CycleListenSeconds < AppConstants.MinimumCycleListenSeconds || settings.CycleListenSeconds > AppConstants.MaximumCycleListenSeconds)
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(settings.CycleListenSeconds));
            return false;
        }

        return TryValidateProfileAudioSpyMappings(settings.AudioSpyMappings, out errorText) &&
            TryValidateProfileRememberedDevice(settings.RememberedBluetoothDevice, out errorText);
    }

    private bool TryValidateProfileAudioSpyMappings(IReadOnlyList<AudioSpyMapping>? mappings, out string errorText)
    {
        errorText = "";

        if (mappings is null || mappings.Count > AppConstants.MaximumAudioSpyMappings)
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(PersistedApplicationSettings.AudioSpyMappings));
            return false;
        }

        foreach (var mapping in mappings)
        {
            var keywords = ApplicationStateStore.NormalizeCsvValues(mapping.Keywords);
            var commands = ApplicationStateStore.NormalizeCsvValues(mapping.Commands);

            if (keywords.Count == 0 || commands.Count == 0)
            {
                errorText = GermanText.GetProfileInvalidValue(nameof(PersistedApplicationSettings.AudioSpyMappings));
                return false;
            }

            foreach (var keyword in keywords)
            {
                if (!AudioSpyMatcher.TryValidateKeyword(keyword, out errorText))
                {
                    return false;
                }
            }
        }

        return true;
    }

    private static bool TryValidateProfileRememberedDevice(RememberedBluetoothDevice? rememberedBluetoothDevice, out string errorText)
    {
        errorText = "";

        if (rememberedBluetoothDevice is null)
        {
            return true;
        }

        if (string.IsNullOrWhiteSpace(rememberedBluetoothDevice.Id) ||
            string.IsNullOrWhiteSpace(rememberedBluetoothDevice.Name) ||
            string.IsNullOrWhiteSpace(rememberedBluetoothDevice.LastConnectedDate) ||
            !DateTime.TryParseExact(rememberedBluetoothDevice.LastConnectedDate, "dd.MM.yyyy", CultureInfo.GetCultureInfo("de-DE"), DateTimeStyles.None, out _) ||
            (rememberedBluetoothDevice.SignalStrength is < -127 or > 20) ||
            !Guid.TryParse(rememberedBluetoothDevice.ServiceUuid, out _) ||
            !Guid.TryParse(rememberedBluetoothDevice.ReceiveCharacteristicUuid, out _) ||
            !Guid.TryParse(rememberedBluetoothDevice.TransmitCharacteristicUuid, out _))
        {
            errorText = GermanText.GetProfileInvalidValue(nameof(PersistedApplicationSettings.RememberedBluetoothDevice));
            return false;
        }

        return true;
    }

    private async Task SetCameraViewStyle(CameraViewStyle cameraViewStyle) =>
        await UpdateStateAndSaveAsync(currentState => currentState with { SelectedCameraViewStyle = cameraViewStyle });

    private async Task SetVideoSourceType(VideoSourceType videoSourceType) =>
        await UpdateStateAndSaveAsync(currentState => currentState with
        {
            SelectedVideoSourceType = ApplicationStateStore.NormalizeVideoSourceType(videoSourceType),
            IsFakeVideoPaused = false
        });

    private async Task SetTestVideoFileSelection(TestVideoFileSelection testVideoFileSelection)
    {
        StateStore.Update(currentState => currentState with
        {
            SelectedVideoSourceType = testVideoFileSelection.IsRegistered
                ? VideoSourceType.TestVideo
                : currentState.SelectedVideoSourceType,
            SelectedTestVideoFileName = testVideoFileSelection.FileName,
            IsTestVideoFileRegistered = testVideoFileSelection.IsRegistered,
            TestVideoSelectionErrorText = testVideoFileSelection.ErrorText,
            IsFakeVideoPaused = false
        });

        await SaveSettingsAsync();
    }

    private async Task SetCameraButtonAppearance(CameraButtonAppearance cameraButtonAppearance) =>
        await UpdateStateAndSaveAsync(currentState => currentState with
        {
            SelectedCameraButtonAppearance = ApplicationStateStore.NormalizeCameraButtonAppearance(cameraButtonAppearance)
        });

    private async Task SetCameraButtonOpacity(double opacity) =>
        await UpdateStateAndSaveAsync(currentState => currentState with { CustomCameraButtonOpacity = ApplicationStateStore.ClampCameraButtonOpacity(opacity) });

    private async Task SetCycleSleepSeconds(int deltaSeconds) =>
        await UpdateStateAndSaveAsync(currentState => currentState with
        {
            CycleSleepSeconds = ApplicationStateStore.ClampInteger(
                currentState.CycleSleepSeconds + deltaSeconds,
                AppConstants.MinimumCycleSleepSeconds,
                AppConstants.MaximumCycleSleepSeconds)
        });

    private async Task SetCycleListenSeconds(int deltaSeconds) =>
        await UpdateStateAndSaveAsync(currentState => currentState with
        {
            CycleListenSeconds = ApplicationStateStore.ClampInteger(
                currentState.CycleListenSeconds + deltaSeconds,
                AppConstants.MinimumCycleListenSeconds,
                AppConstants.MaximumCycleListenSeconds)
        });

    private async Task SetDisplayInverted(bool nextValue)
    {
        await UpdateStateAndSaveAsync(currentState => currentState with { IsDisplayInverted = nextValue });

        if (State.IsConnected)
        {
            await CommandService.SendCommandAsync(nextValue ? "I1" : "I0");
        }
    }

    private async Task SetDisplayRotated(bool nextValue)
    {
        await UpdateStateAndSaveAsync(currentState => currentState with { IsDisplayRotated = nextValue });

        if (State.IsConnected)
        {
            await CommandService.SendCommandAsync(nextValue ? "U1" : "U0");
        }
    }

    private async Task SynchronizeDisplaySettingsAsync()
    {
        await CommandService.SendCommandAsync(State.IsDisplayInverted ? "I1" : "I0");
        await CommandService.SendCommandAsync(State.IsDisplayRotated ? "U1" : "U0");
    }

    private void OpenFullScreenMode(ModeLabel modeLabel)
    {
        UpdateState(currentState => currentState with
        {
            SelectedMode = modeLabel,
            FullScreenMode = modeLabel,
            AreFullScreenControlsVisible = false,
            WasCardSuitButtonPressed = false,
            SymbolText = "",
            RecordingStartedAt = DateTimeOffset.Now,
            RecordingElapsedSeconds = 0,
            IsFakeVideoPaused = false
        });
        StartRecordingTimer();
    }

    private void OpenAudioSpy()
    {
        UpdateState(currentState => currentState with { SelectedClientSubMode = ClientSubMode.AudioSpy });
    }

    private void CloseAudioSpy()
    {
        UpdateState(currentState => currentState with { SelectedClientSubMode = ClientSubMode.Peeker });
    }

    private void ReturnToPeeker()
    {
        UpdateState(currentState => currentState with
        {
            SelectedMenuItem = MenuItem.Client,
            SelectedClientSubMode = ClientSubMode.Peeker,
            IsMenuOpen = false
        });
    }

    private void CloseFullScreenMode()
    {
        StopRecordingTimer();
        UpdateState(currentState => currentState with
        {
            SelectedMenuItem = MenuItem.Client,
            SelectedClientSubMode = ClientSubMode.Peeker,
            FullScreenMode = null,
            AreFullScreenControlsVisible = false,
            RecordingStartedAt = null,
            RecordingElapsedSeconds = 0
        });
    }

    private void SelectCardSuit(string suitCode)
    {
        UpdateState(currentState => currentState with
        {
            SelectedSuitCode = suitCode,
            WasCardSuitButtonPressed = true
        });
    }

    private void SetSymbolText(string symbolText)
    {
        UpdateState(currentState => currentState with { SymbolText = symbolText[..Math.Min(2, symbolText.Length)].ToUpperInvariant() });
    }

    private void SetFakeVideoPaused(bool nextValue)
    {
        UpdateState(currentState => currentState with { IsFakeVideoPaused = nextValue });
    }

    private void SetCameraZoom(double nextValue)
    {
        UpdateState(currentState => currentState with { CameraZoom = ApplicationStateStore.ClampCameraZoom(nextValue) });
    }

    private void StartRecordingTimer()
    {
        StopRecordingTimer();
        recordingTimer = new Timer(_ =>
        {
            if (State.RecordingStartedAt is null)
            {
                return;
            }

            var elapsedSeconds = (int)Math.Floor((DateTimeOffset.Now - State.RecordingStartedAt.Value).TotalSeconds);
            StateStore.Update(currentState => currentState with { RecordingElapsedSeconds = elapsedSeconds });
        }, null, TimeSpan.Zero, TimeSpan.FromSeconds(1));
    }

    private void StopRecordingTimer()
    {
        recordingTimer?.Dispose();
        recordingTimer = null;
    }

    public void Dispose()
    {
        StopRecordingTimer();
        backHandlerRegistration?.Dispose();
        StateStore.StateChanged -= HandleStateChanged;
    }
}
